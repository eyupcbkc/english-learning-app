  "grammar": {
    "title": "Subject Pronouns & Verb 'Be'",
    "titleTr": "Kişi Zamirleri ve 'Be' Fiili",
    "explanation": "In English, we use subject pronouns (I, you, he, she, it, we, they) with the verb 'be' (am, is, are) to introduce ourselves and describe people.",
    "explanationTr": "İngilizce'de kişi zamirleri (I, you, he, she, it, we, they) ile 'be' fiili (am, is, are) kullanarak kendimizi tanıtır ve insanları tanımlarız.",
    "table": [
      ["I", "am", "Ben ...yım/...yim", "I am Eyüp."],
      ["You", "are", "Sen ...sın/...sin", "You are my friend."],
      ["He", "is", "O (erkek) ...dır", "He is a teacher."],
      ["She", "is", "O (kadın) ...dır", "She is from Turkey."],
      ["It", "is", "O (cansız/hayvan) ...dır", "It is a book."],
      ["We", "are", "Biz ...yız/...yiz", "We are students."],
      ["They", "are", "Onlar ...dırlar", "They are happy."]
    ],
    "tips": [
      { "en": "I am = I'm", "tr": "Kısaltma: I am → I'm" },
      { "en": "You are = You're", "tr": "Kısaltma: You are → You're" },
      { "en": "He is = He's / She is = She's", "tr": "Kısaltma: He is → He's, She is → She's" },
      { "en": "We are = We're / They are = They're", "tr": "Kısaltma: We are → We're, They are → They're" }
    ]
  },

  "reading": {
    "text": "Hello! My name is Eyüp. I am from Turkey. I am a student. Nice to meet you! This is my friend, Ayşe. She is from Istanbul. She is very nice. We are happy to be here.",
    "textTr": "Merhaba! Benim adım Eyüp. Ben Türkiye'denim. Ben bir öğrenciyim. Tanıştığıma memnun oldum! Bu benim arkadaşım, Ayşe. O İstanbul'dan. O çok iyi biri. Burada olmaktan mutluyuz.",
    "questions": [
      {
        "question": "Where is Eyüp from?",
        "questionTr": "Eyüp nereden?",
        "options": ["Turkey", "Istanbul", "London", "Germany"],
        "correct": 0
      },
      {
        "question": "Who is Ayşe?",
        "questionTr": "Ayşe kim?",
        "options": ["A teacher", "Eyüp's friend", "A doctor", "Eyüp's sister"],
        "correct": 1
      },
      {
        "question": "Where is Ayşe from?",
        "questionTr": "Ayşe nereden?",
        "options": ["Ankara", "Turkey", "Istanbul", "London"],
        "correct": 2
      }
    ]
  },

