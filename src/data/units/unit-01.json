  "dialog": {
    "title": "Meeting a New Friend at a Café",
    "titleTr": "Kafede Yeni Bir Arkadaşla Tanışma",
    "context": "Eyüp bir kafede oturuyor. Yanındaki masadaki Emma ile göz göze geliyor ve sohbet başlıyor.",
    "lines": [
      { "speaker": "A", "speakerName": "Emma", "text": "Hi! Is this seat free?", "textTr": "Selam! Bu koltuk boş mu?" },
      { "speaker": "B", "speakerName": "Eyüp", "text": "Yes, please sit down!", "textTr": "Evet, buyurun oturun!" },
      { "speaker": "A", "speakerName": "Emma", "text": "Thank you! My name is Emma. What's your name?", "textTr": "Teşekkürler! Benim adım Emma. Senin adın ne?" },
      { "speaker": "B", "speakerName": "Eyüp", "text": "I'm Eyüp. Nice to meet you, Emma!", "textTr": "Ben Eyüp. Tanıştığıma memnun oldum, Emma!" },
      { "speaker": "A", "speakerName": "Emma", "text": "Nice to meet you too! Where are you from?", "textTr": "Ben de memnun oldum! Nerelisin?" },
      { "speaker": "B", "speakerName": "Eyüp", "text": "I'm from Turkey. And you?", "textTr": "Türkiye'denim. Ya sen?" },
      { "speaker": "A", "speakerName": "Emma", "text": "I'm from Boston, in the United States. I'm here on vacation.", "textTr": "Boston'danım, Amerika. Tatil için buradayım." },
      { "speaker": "B", "speakerName": "Eyüp", "text": "That's great! How are you liking Turkey?", "textTr": "Harika! Türkiye'yi nasıl buluyorsun?" },
      { "speaker": "A", "speakerName": "Emma", "text": "I love it! The food is amazing and people are so friendly.", "textTr": "Bayıldım! Yemekler harika ve insanlar çok samimi." },
      { "speaker": "B", "speakerName": "Eyüp", "text": "Thank you! That's very nice. I am learning English now.", "textTr": "Teşekkürler! Bu çok güzel. Şu an İngilizce öğreniyorum." },
      { "speaker": "A", "speakerName": "Emma", "text": "Your English is good! Keep going!", "textTr": "İngilizce'n iyi! Devam et!" },
      { "speaker": "B", "speakerName": "Eyüp", "text": "Thank you so much! It was nice meeting you. See you!", "textTr": "Çok teşekkürler! Tanıştığıma memnun oldum. Görüşürüz!" },
      { "speaker": "A", "speakerName": "Emma", "text": "See you, Eyüp! Goodbye!", "textTr": "Görüşürüz, Eyüp! Hoşça kal!" }
    ],
