  "grammar": {
    "title": "Subject Pronouns & Verb 'Be'",
    "titleTr": "Kişi Zamirleri ve 'Be' Fiili",
    "explanation": "In English, we use subject pronouns (I, you, he, she, it, we, they) with the verb 'be' (am, is, are) to introduce ourselves, describe people, and talk about feelings.",
    "explanationTr": "İngilizce'de kişi zamirleri (I, you, he, she, it, we, they) ile 'be' fiili (am, is, are) kullanarak kendimizi tanıtır, insanları tanımlar ve duygularımızdan bahsederiz.",
    "table": [
      ["I", "am", "Ben ...yım/...yim", "I am Eyüp. I am from Turkey."],
      ["You", "are", "Sen ...sın/...sin", "You are my friend. You are nice."],
      ["He", "is", "O (erkek) ...dır", "He is a teacher. He is tall."],
      ["She", "is", "O (kadın) ...dır", "She is from Istanbul. She is happy."],
      ["It", "is", "O (cansız/hayvan) ...dır", "It is a book. It is cold today."],
      ["We", "are", "Biz ...yız/...yiz", "We are students. We are ready."],
      ["They", "are", "Onlar ...dırlar", "They are friends. They are from Ankara."]
    ],
    "tips": [
      { "en": "I am = I'm", "tr": "Kısaltma: I am → I'm (konuşmada çok kullanılır)" },
      { "en": "You are = You're", "tr": "Kısaltma: You are → You're" },
      { "en": "He is = He's / She is = She's / It is = It's", "tr": "He's, She's, It's hep kullanılır" },
      { "en": "We are = We're / They are = They're", "tr": "We're, They're — yazıda ve konuşmada yaygın" },
      { "en": "My name is... = I'm...", "tr": "Tanışırken ikisi de olur: My name is Eyüp. / I'm Eyüp." },
      { "en": "Nice to meet you! → Nice to meet you too!", "tr": "Tanışınca: Memnun oldum! → Ben de!" }
    ]
  },

  "reading": {
    "text": "Hello! My name is Eyüp. I am from Turkey. I am 25 years old and I am a student. I am learning English because I want to travel and work internationally.\n\nThis is my friend Ayşe. She is from Istanbul. She is a designer and she is very creative. We are in the same English class.\n\nOur teacher is Mr. Johnson. He is from America. He is friendly and funny. There are 12 students in our class. We are all beginners, but we are excited to learn!\n\nAfter class, Ayşe and I go to a café. We practice English together. It is fun! Learning English is not easy, but it is important for our future.",
    "textTr": "Merhaba! Benim adım Eyüp. Ben Türkiye'denim. 25 yaşındayım ve öğrenciyim. Seyahat etmek ve uluslararası çalışmak istediğim için İngilizce öğreniyorum.\n\nBu benim arkadaşım Ayşe. O İstanbul'dan. Tasarımcı ve çok yaratıcı. Aynı İngilizce sınıfındayız.\n\nÖğretmenimiz Bay Johnson. O Amerikalı. Samimi ve eğlenceli. Sınıfımızda 12 öğrenci var. Hepimiz başlangıç seviyesindeyiz ama öğrenmeye heyecanlıyız!\n\nDersten sonra Ayşe ile bir kafeye gideriz. Birlikte İngilizce pratik yaparız. Eğlenceli! İngilizce öğrenmek kolay değil ama geleceğimiz için önemli.",
    "questions": [
      {
        "question": "Why is Eyüp learning English?",
        "questionTr": "Eyüp neden İngilizce öğreniyor?",
        "options": ["Because it is easy", "To travel and work internationally", "Because his friend wants to", "For fun only"],
        "correct": 1
      },
      {
        "question": "What is Ayşe's job?",
        "questionTr": "Ayşe'nin mesleği ne?",
        "options": ["Teacher", "Student", "Designer", "Doctor"],
        "correct": 2
      },
      {
        "question": "Where is Mr. Johnson from?",
        "questionTr": "Bay Johnson nereli?",
        "options": ["Turkey", "England", "America", "Germany"],
        "correct": 2
      },
      {
        "question": "How many students are in the class?",
        "questionTr": "Sınıfta kaç öğrenci var?",
        "options": ["10", "12", "15", "20"],
        "correct": 1
      },
      {
        "question": "What do Eyüp and Ayşe do after class?",
        "questionTr": "Eyüp ve Ayşe dersten sonra ne yapar?",
        "options": ["Go home", "Go to a café and practice English", "Watch TV", "Go shopping"],
        "correct": 1
      }
    ]
  },

