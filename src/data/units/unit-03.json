  "grammar": {
    "title": "Verb 'Be' - Positive, Negative & Questions",
    "titleTr": "'Be' Fiili - Olumlu, Olumsuz ve Soru Cümleleri",
    "explanation": "The verb 'be' has three forms: am, is, are. For negative, add 'not' after the verb. For questions, move the verb before the subject.",
    "explanationTr": "'Be' fiilinin üç hali var: am, is, are. Olumsuz yapmak için fiilden sonra 'not' eklenir. Soru yapmak için fiil öznenin önüne geçer.",
    "table": [
      ["I am happy.", "I am not happy.", "Am I happy?", "Ben mutluyum / değilim / muyum?"],
      ["You are tall.", "You are not tall.", "Are you tall?", "Sen uzunsun / değilsin / musun?"],
      ["He is a doctor.", "He is not a doctor.", "Is he a doctor?", "O doktor / değil / mı?"],
      ["She is tired.", "She is not tired.", "Is she tired?", "O yorgun / değil / mı?"],
      ["It is cold.", "It is not cold.", "Is it cold?", "Soğuk / değil / mı?"],
      ["We are ready.", "We are not ready.", "Are we ready?", "Hazırız / değiliz / mıyız?"],
      ["They are students.", "They are not students.", "Are they students?", "Onlar öğrenci / değil / mi?"]
    ],
    "tips": [
      { "en": "is not = isn't, are not = aren't", "tr": "Kısaltma: is not → isn't, are not → aren't" },
      { "en": "am not = I'm not (no 'amn't'!)", "tr": "'am not' kısaltması: I'm not (amn't diye bir şey YOK!)" },
      { "en": "Short answers: Yes, I am. / No, I'm not.", "tr": "Kısa cevap: Yes, I am. / No, I'm not." },
      { "en": "Short answers: Yes, he is. / No, he isn't.", "tr": "Kısa cevap: Yes, he is. / No, he isn't." }
    ]
  },

  "reading": {
    "text": "Hello! I am Mehmet. I am not a teacher. I am a student. I am twenty years old. I am from Ankara. My friend Ali is tall. He is not short. He is a doctor. We are not in the same class, but we are good friends. Are you a student too?",
    "textTr": "Merhaba! Ben Mehmet. Ben öğretmen değilim. Ben bir öğrenciyim. Yirmi yaşındayım. Ankara'lıyım. Arkadaşım Ali uzun boylu. O kısa değil. O bir doktor. Aynı sınıfta değiliz ama iyi arkadaşız. Sen de öğrenci misin?",
    "questions": [
      {
        "question": "Is Mehmet a teacher?",
        "questionTr": "Mehmet öğretmen mi?",
        "options": ["Yes, he is.", "No, he isn't.", "Yes, he does.", "No, he doesn't."],
        "correct": 1
      },
      {
        "question": "Where is Mehmet from?",
        "questionTr": "Mehmet nereli?",
        "options": ["Istanbul", "Ankara", "Izmir", "Bursa"],
        "correct": 1
      },
      {
        "question": "Is Ali short?",
        "questionTr": "Ali kısa mı?",
        "options": ["Yes, he is.", "No, he isn't.", "Yes, he are.", "No, he not."],
        "correct": 1
      },
      {
        "question": "What is Ali's job?",
        "questionTr": "Ali'nin mesleği ne?",
        "options": ["Student", "Teacher", "Doctor", "Engineer"],
        "correct": 2
      }
    ]
  },

