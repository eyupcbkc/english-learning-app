  "grammar": {
    "title": "Numbers & 'How many / How old'",
    "titleTr": "Sayılar ve 'Kaç tane / Kaç yaşında' Soruları",
    "explanation": "In English, we use 'How many' to ask about quantity and 'How old' to ask about age. Numbers follow the same pattern: one, two, three... For bigger numbers: twenty-one (21), thirty-five (35), one hundred (100).",
    "explanationTr": "İngilizce'de 'How many' miktar sormak için, 'How old' yaş sormak için kullanılır. Büyük sayılar: twenty-one (21), thirty-five (35), one hundred (100) şeklinde yazılır.",
    "table": [
      ["1-5", "one, two, three, four, five", "bir, iki, üç, dört, beş", "I have five books."],
      ["6-10", "six, seven, eight, nine, ten", "altı, yedi, sekiz, dokuz, on", "There are ten chairs."],
      ["11-20", "eleven, twelve, ... twenty", "on bir, on iki, ... yirmi", "She is twenty years old."],
      ["30-100", "thirty, forty, fifty ... hundred", "otuz, kırk, elli ... yüz", "There are fifty students."],
      ["How many?", "How many + plural noun", "Kaç tane?", "How many books do you have?"],
      ["How old?", "How old + are/is + subject", "Kaç yaşında?", "How old are you?"]
    ],
    "tips": [
      { "en": "11 = eleven, 12 = twelve (special!)", "tr": "11 ve 12 özel isimler: eleven, twelve" },
      { "en": "13-19: thirteen, fourteen... (+ teen)", "tr": "13-19 arası -teen ile biter" },
      { "en": "20, 30, 40... twenty, thirty, forty (+ ty)", "tr": "Onluklar -ty ile biter" },
      { "en": "Days & months always start with CAPITAL letter", "tr": "Günler ve aylar her zaman BÜYÜK harfle başlar" }
    ]
  },

  "reading": {
    "text": "My name is Ayşe. I am twenty-three years old. My birthday is in March. Today is Monday. I go to English class on Monday and Wednesday. There are fifteen students in my class. On the weekend, I like to read books. I have thirty books at home!",
    "textTr": "Benim adım Ayşe. Yirmi üç yaşındayım. Doğum günüm Mart'ta. Bugün Pazartesi. Pazartesi ve Çarşamba İngilizce dersine giderim. Sınıfımda on beş öğrenci var. Hafta sonu kitap okumayı severim. Evde otuz kitabım var!",
    "questions": [
      {
        "question": "How old is Ayşe?",
        "questionTr": "Ayşe kaç yaşında?",
        "options": ["20", "23", "25", "30"],
        "correct": 1
      },
      {
        "question": "When is her birthday?",
        "questionTr": "Doğum günü ne zaman?",
        "options": ["January", "February", "March", "April"],
        "correct": 2
      },
      {
        "question": "How many students are in her class?",
        "questionTr": "Sınıfında kaç öğrenci var?",
        "options": ["10", "12", "15", "20"],
        "correct": 2
      },
      {
        "question": "How many books does she have?",
        "questionTr": "Kaç kitabı var?",
        "options": ["13", "20", "25", "30"],
        "correct": 3
      }
    ]
  },

